{
  "name": "stickynotes",
  "version": "2.0.0",
  "description": "A feature-rich sticky notes application with CLI support",
  "main": "electron/main.js",
  "bin": {
    "stickynotes": "./cli/bin/stickynotes.js"
  },
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "lint": "eslint .",
    "test": "jest",
    "test:unit": "jest --testPathPattern=test/unit",
    "test:integration": "jest --testPathPattern=test/integration",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:verbose": "jest --verbose",
    "test:ci": "jest --ci --coverage --reporters=default --reporters=jest-junit",
    "setup": "node scripts/setup.mjs",
    "setup:electron": "node scripts/setup.mjs --electron",
    "setup:whisper": "node scripts/setup.mjs --electron --whisper",
    "setup:whisper:tiny": "node scripts/setup.mjs --electron --whisper --model=tiny",
    "setup:whisper:small": "node scripts/setup.mjs --electron --whisper --model=small",
    "rebuild": "npm rebuild better-sqlite3",
    "rebuild:electron": "electron-rebuild",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "StickyNotes Team <stickynotes@example.com>",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.16",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.6.0",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.3",
    "decompress": "^4.2.1",
    "decompress-tarbz2": "^4.1.1",
    "electron-updater": "^6.1.7",
    "marked": "^12.0.0",
    "nanoid": "^3.3.7",
    "sherpa-onnx-node": "^1.10.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0"
  }
}

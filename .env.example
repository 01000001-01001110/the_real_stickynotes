# StickyNotes Environment Variables
# Copy this file to .env to customize your development environment

# Development mode - enables debug logging
# NODE_ENV=development

# GitHub Personal Access Token (optional)
# Only needed for development/testing of auto-update features
# GITHUB_TOKEN=your_github_token_here

# Custom data directory (optional)
# Overrides the default app data directory
# STICKYNOTES_DATA_DIR=/path/to/custom/data

# Debug logging (optional)
# Set to 1 to enable verbose debug output
# DEBUG=1
